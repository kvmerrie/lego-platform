# apps/api
# Server-only values. Never expose these to browser code or public client bundles.
# For staging and production, mirror these values in the target Render API service only.
# Local add-set/admin writes use SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY.
# If NEXT_PUBLIC_SUPABASE_URL is also present in the same shell or process, it must
# point to the same Supabase project. The API will now fail fast when they diverge.

# apps/api -> Supabase server connection
SUPABASE_URL=__FILL_ME__
SUPABASE_SERVICE_ROLE_KEY=__FILL_ME__

# apps/api -> optional local overrides
HOST=localhost
PORT=3333
