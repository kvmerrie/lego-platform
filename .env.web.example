# apps/web
# Copy the values you need into your normal untracked local env workflow.
# For staging and production, mirror these values in the target Vercel project only.

# apps/web -> API proxy target used by the Next.js rewrite for /api/*
API_PROXY_TARGET=http://localhost:3333

# apps/web -> browser-safe Supabase values
NEXT_PUBLIC_SUPABASE_URL=__FILL_ME__
NEXT_PUBLIC_SUPABASE_ANON_KEY=__FILL_ME__

# apps/web -> Contentful delivery values for live editorial content
CONTENTFUL_SPACE_ID=__FILL_ME__
CONTENTFUL_DELIVERY_ACCESS_TOKEN=__FILL_ME__
CONTENTFUL_ENVIRONMENT=master

# apps/web -> Contentful preview values for editorial preview only
CONTENTFUL_PREVIEW_ACCESS_TOKEN=__FILL_ME__
CONTENTFUL_PREVIEW_SECRET=__FILL_ME__
