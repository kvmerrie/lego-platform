# operator/CI sync workflows
# These values are only needed for catalog sync or secret-backed CI validation.
# For staging and production, mirror these only in operator shells or CI jobs, not in the web app.

# apps/catalog-sync -> Supabase-first canonical catalog access
SUPABASE_URL=__FILL_ME__
SUPABASE_SERVICE_ROLE_KEY=__FILL_ME__

# Rebrickable remains needed for add-set/backfill/theme-enrichment workflows
REBRICKABLE_API_KEY=__FILL_ME__
REBRICKABLE_BASE_URL=https://rebrickable.com/api/v3

# TradeTracker Alternate affiliate feed sync
TRADETRACKER_CUSTOMER_ID=__FILL_ME__
TRADETRACKER_PASSPHRASE=__FILL_ME__
# Optional but recommended when the TradeTracker account has multiple affiliate sites
TRADETRACKER_AFFILIATE_SITE_ID=__FILL_ME__
# Optional explicit feed selection overrides when heuristic Alternate matching is ambiguous
TRADETRACKER_ALTERNATE_FEED_ID=__FILL_ME__
TRADETRACKER_ALTERNATE_CAMPAIGN_ID=__FILL_ME__

# Awin Coolblue affiliate product feed sync
AWIN_COOLBLUE_FEED_URL=__FILL_ME__
AWIN_COOLBLUE_MERCHANT_SLUG=coolblue
AWIN_COOLBLUE_MERCHANT_NAME=Coolblue
