{
  "name": "catalog-sync",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/catalog-sync/src",
  "projectType": "application",
  "tags": ["scope:catalog", "type:app", "platform:server"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/catalog-sync",
        "format": ["cjs"],
        "bundle": true,
        "main": "apps/catalog-sync/src/main.ts",
        "tsConfig": "apps/catalog-sync/tsconfig.app.json",
        "assets": []
      },
      "configurations": {
        "development": {},
        "production": {
          "esbuildOptions": {
            "sourcemap": false
          }
        }
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/apps/catalog-sync/main.cjs"
      }
    }
  }
}
